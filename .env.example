# ─── MaxiFitness Environment Variables ───────────────────────────────────────
# Copy this file to `.env` and fill in the values.
#   cp .env.example .env

# ChowAPI key for barcode nutrition lookups
# Get one at https://chowapi.dev (Builder pack: $20 for 25,000 lookups)
CHOW_API_KEY=your_chow_api_key_here

# Flask secret key — used for session cookies.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Database path (optional — defaults to ./maxifitness.db)
# MAXIFITNESS_DB=/path/to/your/maxifitness.db

# Flask host and port (optional — defaults in launch-pi.sh)
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
